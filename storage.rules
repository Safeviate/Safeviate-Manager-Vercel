rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/{tenantId}/branding/sidebar/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
