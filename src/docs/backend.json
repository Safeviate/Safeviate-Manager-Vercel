
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user's link between authentication and their profile data.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePath": { "type": "string" }
      },
      "required": ["id", "email", "profilePath"]
    },
    "QuestionBankItem": {
      "title": "Question Bank Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "topic": { "type": "string" },
        "text": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" }
            },
            "required": ["id", "text"]
          }
        },
        "correctOptionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "topic", "text", "options", "correctOptionId"]
    },
    "ExamTemplate": {
      "title": "Exam Template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "passingScore": { "type": "number" },
        "questions": { "type": "array", "items": { "$ref": "#/backend/entities/QuestionBankItem" } }
      },
      "required": ["id", "title", "subject", "passingScore"]
    },
    "ExamResult": {
      "title": "Exam Result",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "templateId": { "type": "string" },
        "studentId": { "type": "string" },
        "score": { "type": "number" },
        "passed": { "type": "boolean" },
        "isMock": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile link."
        }
      },
      {
        "path": "tenants/{tenantId}/question-pool/{questionId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/QuestionBankItem" },
          "description": "Central pool of aviation questions categorized by topic."
        }
      },
      {
        "path": "tenants/{tenantId}/exam-templates/{templateId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/ExamTemplate" },
          "description": "Official exam templates."
        }
      },
      {
        "path": "tenants/{tenantId}/student-exam-results/{resultId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/ExamResult" },
          "description": "Historical exam performance records."
        }
      }
    ]
  }
}
