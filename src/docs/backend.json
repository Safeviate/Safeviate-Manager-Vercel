
{
  "entities": {
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "Represents a booking for an aircraft.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the booking."
        },
        "bookingNumber": {
            "type": "number",
            "description": "A sequential, human-readable booking number."
        },
        "aircraftId": {
          "type": "string",
          "description": "The ID of the booked aircraft."
        },
        "pilotId": {
          "type": "string",
          "description": "The ID of the pilot who made the booking."
        },
        "instructorId": {
            "type": "string",
            "description": "The ID of the instructor for a training flight."
        },
        "type": {
          "type": "string",
          "description": "The type of booking.",
          "enum": ["Training Flight", "Private Flight", "Reposition Flight", "Maintenance Flight"]
        },
        "bookingDate": {
          "type": "string",
          "format": "date",
          "description": "The date of the booking (YYYY-MM-DD)."
        },
        "startTime": {
          "type": "string",
          "description": "The start time of the booking (HH:mm)."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the booking (HH:mm)."
        },
        "status": {
            "type": "string",
            "description": "The status of the booking.",
            "enum": ["Confirmed", "Completed", "Cancelled", "Cancelled with Reason"]
        },
        "isOvernight": {
            "type": "boolean",
            "description": "Flag to indicate if the booking spans across midnight."
        },
        "overnightBookingDate": {
            "type": "string",
            "format": "date",
            "description": "The date for the second part of an overnight booking (YYYY-MM-DD)."
        },
        "overnightEndTime": {
            "type": "string",
            "description": "The end time for the second part of an overnight booking (HH:mm)."
        },
        "preFlight": {
            "type": "object",
            "description": "Pre-flight checklist data.",
            "properties": {
                "actualHobbs": { "type": "number" },
                "actualTacho": { "type": "number" },
                "oil": { "type": "number" },
                "fuel": { "type": "number" },
                "documentsChecked": { "type": "array", "items": { "type": "string" } }
            }
        },
        "postFlight": {
            "type": "object",
            "description": "Post-flight checklist data.",
            "properties": {
                "actualHobbs": { "type": "number" },
                "actualTacho": { "type": "number" },
                "oil": { "type": "number" },
                "fuel": { "type": "number" }
            }
        }
      },
      "required": ["id", "aircraftId", "pilotId", "type", "bookingDate", "startTime", "endTime"]
    },
    "AircraftModelProfile": {
      "title": "Aircraft Model Profile",
      "type": "object",
      "description": "Represents a mass and balance template for a specific aircraft make and model.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the profile." },
        "profileName": { "type": "string", "description": "The unique name for this M&B profile." },
        "emptyWeight": { "type": "number", "description": "The standard empty weight of this aircraft model (in lbs)." },
        "emptyWeightMoment": { "type": "number", "description": "The standard moment of this model at its empty weight (in lbs-in)." },
        "maxTakeoffWeight": { "type": "number", "description": "Maximum allowable takeoff weight (in lbs)." },
        "maxLandingWeight": { "type": "number", "description": "Maximum allowable landing weight (in lbs)." },
        "stationArms": {
          "type": "object",
          "description": "Defines the arm (distance from datum in inches) for each station.",
          "properties": {
            "frontSeats": { "type": "number", "description": "Arm for the front seats." },
            "rearSeats": { "type": "number", "description": "Arm for the rear seats." },
            "fuel": { "type": "number", "description": "Arm for the fuel tank(s)." },
            "baggage1": { "type": "number", "description": "Arm for the primary baggage area." },
            "baggage2": { "type": "number", "description": "Arm for the secondary baggage area, if applicable." }
          }
        },
        "stations": {
          "type": "array",
          "description": "A list of loading stations for the aircraft model.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "weight": { "type": "number" },
              "arm": { "type": "number" },
              "type": { "type": "string" },
              "gallons": { "type": "number" },
              "maxGallons": { "type": "number" }
            }
          }
        },
        "cgEnvelope": {
          "type": "array",
          "description": "An array of {x, y} objects defining the vertices of the CG envelope polygon.",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number", "description": "Center of Gravity (inches)" },
              "y": { "type": "number", "description": "Weight (lbs)" }
            },
            "required": ["x", "y"]
          }
        },
        "xMin": { "type": "number", "description": "Minimum value for the CG chart's X-axis (CG)." },
        "xMax": { "type": "number", "description": "Maximum value for the CG chart's X-axis (CG)." },
        "yMin": { "type": "number", "description": "Minimum value for the CG chart's Y-axis (Weight)." },
        "yMax": { "type": "number", "description": "Maximum value for the CG chart's Y-axis (Weight)." }
      },
      "required": ["id", "profileName"]
    },
    "PilotProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PilotProfile",
      "type": "object",
      "description": "Represents a pilot's profile, including students, private pilots, and instructors.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PilotProfile entity."
        },
        "userType": {
          "type": "string",
          "description": "The category of the user.",
          "enum": ["Student", "Private Pilot", "Instructor"]
        },
        "firstName": {
          "type": "string",
          "description": "Pilot's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Pilot's last name."
        },
        "email": {
          "type": "string",
          "description": "Pilot's email address.",
          "format": "email"
        },
        "contactNumber": { "type": "string", "description": "The contact phone number of the pilot." },
        "dateOfBirth": { "type": "string", "description": "The pilot's date of birth.", "format": "date" },
        "address": { "$ref": "#/backend/entities/Address" },
        "emergencyContact": { "$ref": "#/backend/entities/EmergencyContact" },
        "documents": { "$ref": "#/backend/entities/Documents" },
        "pilotLicense": { "$ref": "#/backend/entities/PilotLicense" }
      },
      "required": ["id", "userType", "firstName", "lastName", "email"]
    },
    "Personnel": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Personnel",
      "type": "object",
      "description": "Represents a non-flying staff member at the aviation academy.",
      "properties": {
        "id_": {
          "type": "string",
          "description": "Unique identifier for the Personnel entity."
        },
        "userType": {
          "type": "string",
          "description": "The category of the user, fixed to 'Personnel'.",
          "enum": ["Personnel"]
        },
        "firstName": {
          "type": "string",
          "description": "Personnel's first name."
        },
        "lastName": {
          "type": "string",
          "description": "Personnel's last name."
        },
        "role": {
          "type": "string",
          "description": "The ID of the role assigned to the personnel."
        },
        "email": {
          "type": "string",
          "description": "Personnel's email address.",
          "format": "email"
        },
        "permissions": {
          "type": "array",
          "description": "An array of permission IDs (strings) associated with this person, potentially overriding the role.",
          "items": { "type": "string" }
        },
        "department": {
          "type": "string",
          "description": "The ID of the department the personnel belongs to."
        },
        "contactNumber": { "type": "string", "description": "The contact phone number of the personnel." },
        "dateOfBirth": { "type": "string", "description": "The personnel's date of birth.", "format": "date" },
        "address": { "$ref": "#/backend/entities/Address" },
        "emergencyContact": { "$ref": "#/backend/entities/EmergencyContact" },
        "documents": { "$ref": "#/backend/entities/Documents" }
      },
      "required": ["id", "userType", "firstName", "lastName", "role", "email"]
    },
    "PilotLicense": {
        "title": "PilotLicense",
        "type": "object",
        "description": "Represents a pilot's license details.",
        "properties": {
            "licenseNumber": { "type": "string", "description": "The pilot's license number." },
            "issueDate": { "type": "string", "format": "date", "description": "The date the license was issued." },
            "expirationDate": { "type": "string", "format": "date", "description": "The date the license expires." },
            "ratings": { 
                "type": "array", 
                "description": "List of ratings held by the pilot.",
                "items": { "type": "string" }
            },
            "endorsements": { 
                "type": "array", 
                "description": "List of endorsements held by the pilot.",
                "items": { "type": "string" }
            }
        }
    },
    "Address": {
        "title": "Address",
        "type": "object",
        "description": "Represents a physical address.",
        "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": { "type": "string" }
        }
    },
    "EmergencyContact": {
        "title": "EmergencyContact",
        "type": "object",
        "description": "Represents an emergency contact.",
        "properties": {
            "name": { "type": "string" },
            "relationship": { "type": "string" },
            "phone": { "type": "string" }
        }
    },
    "Documents": {
        "title": "Documents",
        "type": "array",
        "description": "A list of documents associated with a user or aircraft.",
        "items": {
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "url": { "type": "string", "format": "uri" },
                "uploadDate": { "type": "string", "format": "date-time" },
                "expirationDate": { "type": "string", "format": "date" },
                "abbreviation": { "type": "string", "description": "A 5-character abbreviation for the document." }
            }
        }
    },
    "Aircraft": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Aircraft",
      "type": "object",
      "description": "Represents an aircraft used for training.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Aircraft entity."
        },
        "tailNumber": {
          "type": "string",
          "description": "Aircraft's tail number."
        },
        "model": {
          "type": "string",
          "description": "Aircraft's model."
        },
        "abbreviation": {
          "type": "string",
          "description": "A 5-character abbreviation for the aircraft."
        },
        "type": {
          "type": "string",
          "description": "The type of aircraft.",
          "enum": [
            "Single-Engine",
            "Multi-Engine"
          ]
        },
        "frameHours": {
          "type": "number",
          "description": "Total hours on the aircraft frame."
        },
        "engineHours": {
          "type": "number",
          "description": "Total hours on the engine."
        },
        "initialHobbs": {
          "type": "number",
          "description": "Initial Hobbs meter reading."
        },
        "currentHobbs": {
          "type": "number",
          "description": "Current Hobbs meter reading."
        },
        "initialTacho": {
          "type": "number",
          "description": "Initial Tachometer reading."
        },
        "currentTacho": {
          "type": "number",
          "description": "Current Tachometer reading."
        },
        "tachoAtNext50Inspection": {
          "type": "number",
          "description": "Tacho reading at which the next 50-hour inspection is due."
        },
        "tachoAtNext100Inspection": {
          "type": "number",
          "description": "Tacho reading at which the next 100-hour inspection is due."
        },
        "maintenanceLogs": {
          "type": "array",
          "description": "References to MaintenanceLog entries. (Relationship: Aircraft 1:N MaintenanceLog)",
          "items": {
            "type": "string"
          }
        },
        "documents": {
           "$ref": "#/backend/entities/Documents"
        },
        "emptyWeight": {
          "type": "number",
          "description": "The basic empty weight of the aircraft (in lbs)."
        },
        "emptyWeightMoment": {
          "type": "number",
          "description": "The moment of the aircraft at its basic empty weight (in lbs-in)."
        },
        "maxTakeoffWeight": {
          "type": "number",
          "description": "Maximum allowable takeoff weight (in lbs)."
        },
        "maxLandingWeight": {
          "type": "number",
          "description": "Maximum allowable landing weight (in lbs)."
        },
        "stationArms": {
          "type": "object",
          "description": "Defines the arm (distance from datum in inches) for each station.",
          "properties": {
            "frontSeats": { "type": "number", "description": "Arm for the front seats." },
            "rearSeats": { "type": "number", "description": "Arm for the rear seats." },
            "fuel": { "type": "number", "description": "Arm for the fuel tank(s)." },
            "baggage1": { "type": "number", "description": "Arm for the primary baggage area." },
            "baggage2": { "type": "number", "description": "Arm for the secondary baggage area." }
          }
        },
        "cgEnvelope": {
          "type": "array",
          "description": "An array of {weight, cg} objects defining the vertices of the CG envelope polygon.",
          "items": {
            "type": "object",
            "properties": {
              "weight": { "type": "number", "description": "Weight (lbs)" },
              "cg": { "type": "number", "description": "Center of Gravity (inches)" }
            }
          }
        },
        "checklistStatus": {
            "type": "string",
            "description": "Indicates the current pre/post flight checklist status of the aircraft.",
            "enum": ["Ready", "needs-pre-flight", "needs-post-flight"]
        },
        "currentBookingId": {
            "type": "string",
            "description": "The ID of the booking that currently requires a checklist action."
        }
      },
      "required": [
        "id",
        "tailNumber",
        "model"
      ]
    },
    "MaintenanceLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MaintenanceLog",
      "type": "object",
      "description": "Represents a maintenance log entry for an aircraft.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the MaintenanceLog entity."
        },
        "aircraftId": {
          "type": "string",
          "description": "Reference to Aircraft. (Relationship: Aircraft 1:N MaintenanceLog)"
        },
        "date": {
          "type": "string",
          "description": "Date of the maintenance.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the maintenance performed."
        },
        "procedure": {
          "type": "string",
          "description": "Details of the maintenance procedure followed."
        }
      },
      "required": [
        "id",
        "aircraftId",
        "date",
        "description"
      ]
    },
    "SafetyProtocol": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SafetyProtocol",
      "type": "object",
      "description": "Represents a safety protocol.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the SafetyProtocol entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the safety protocol."
        },
        "description": {
          "type": "string",
          "description": "Detailed description of the safety protocol."
        },
        "complianceChecks": {
          "type": "array",
          "description": "References to ComplianceCheck entries. (Relationship: SafetyProtocol 1:N ComplianceCheck)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "ComplianceCheck": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ComplianceCheck",
      "type": "object",
      "description": "Represents a compliance check performed.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ComplianceCheck entity."
        },
        "safetyProtocolId": {
          "type": "string",
          "description": "Reference to SafetyProtocol. (Relationship: SafetyProtocol 1:N ComplianceCheck)"
        },
        "date": {
          "type": "string",
          "description": "Date when the compliance check was performed.",
          "format": "date-time"
        },
        "result": {
          "type": "boolean",
          "description": "Result of the compliance check (true for pass, false for fail)."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes or observations from the compliance check."
        }
      },
      "required": [
        "id",
        "safetyProtocolId",
        "date",
        "result"
      ]
    },
    "Permission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Permission",
      "type": "object",
      "description": "Represents a permission within the application, typically generated from the menu structure.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Permission entity, often derived from the menu href."
        },
        "name": {
          "type": "string",
          "description": "The human-readable name of the permission (e.g., 'Users')."
        },
        "description": {
          "type": "string",
          "description": "A description of what the permission grants."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Represents a role within the application, defining a set of permissions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Role entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the role."
        },
        "permissions": {
          "type": "array",
          "description": "An array of permission IDs (strings) associated with this role.",
          "items": {
            "type": "string"
          }
        },
        "requiredDocuments": {
            "type": "array",
            "description": "A list of document names that a user with this role is required to upload.",
            "items": {
                "type": "string"
            }
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a Tenant on the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Tenant."
        },
        "name": {
          "type": "string",
          "description": "Name of the tenant"
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the company logo."
        },
        "theme": {
          "$ref": "#/backend/entities/Theme"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Theme": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Theme",
      "type": "object",
      "description": "Represents the application theme for a tenant.",
      "properties": {
        "primaryColour": {
          "type": "string",
          "description": "The primary colour to use"
        },
        "backgroundColour": {
          "type": "string",
          "description": "The background colour to use"
        },
        "accentColour": {
          "type": "string",
          "description": "The accent colour to use"
        }
      }
    },
    "Settings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Settings",
      "type": "object",
      "description": "Represents the application settings for a tenant.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Settings."
        },
        "tenantId": {
          "type": "string",
          "description": "The tenant this setting belongs to."
        },
        "theme": {
          "$ref": "#/backend/entities/Theme"
        },
        "documentExpiry": {
            "$ref": "#/backend/entities/DocumentExpiry"
        }
      },
      "required": [
        "id",
        "tenantId"
      ]
    },
    "FeatureSettings": {
      "title": "Feature Settings",
      "type": "object",
      "description": "Represents tenant-wide feature flags and settings.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the feature settings document." },
        "preFlightChecklistRequired": { "type": "boolean", "description": "If true, pre-flight checklists are mandatory and block subsequent bookings if not completed." }
      }
    },
    "WarningPeriod": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "WarningPeriod",
        "type": "object",
        "description": "Represents a single document expiry warning period with its associated color.",
        "properties": {
            "period": {
                "type": "number",
                "description": "The number of days before expiration to send a warning."
            },
            "color": {
                "type": "string",
                "description": "The hex color code associated with this warning period."
            }
        },
        "required": ["period", "color"]
    },
    "DocumentExpiry": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "DocumentExpiry",
        "type": "object",
        "description": "Represents the document expiry warning settings for a tenant.",
        "properties": {
            "defaultColor": {
                "type": "string",
                "description": "The hex color code for documents not within any warning period."
            },
            "expiredColor": {
                "type": "string",
                "description": "The hex color code for documents that have expired."
            },
            "warningPeriods": {
                "type": "array",
                "description": "An array of warning period objects.",
                "items": {
                    "$ref": "#/backend/entities/WarningPeriod"
                }
            }
        },
        "required": ["warningPeriods"]
    },
    "Department": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Department",
      "type": "object",
      "description": "Represents a department within a tenant.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the department."
        },
        "name": {
          "type": "string",
          "description": "Name of the department."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Counter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Counter",
      "type": "object",
      "description": "Represents a distributed counter.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the counter (e.g., 'bookings')."
        },
        "currentNumber": {
          "type": "number",
          "description": "The last number that was used."
        }
      },
      "required": ["id", "currentNumber"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
       {
        "path": "tenants/{tenantId}/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": {
            "$ref": "#/backend/entities/Booking"
          },
          "description": "Stores individual booking records for each tenant.",
          "params": [
            { "name": "tenantId", "description": "Tenant ID." },
            { "name": "bookingId", "description": "Booking ID." }
          ]
        }
      },
      {
        "path": "tenants/{tenantId}/massAndBalance/{profileId}",
        "definition": {
          "entityName": "AircraftModelProfile",
          "schema": {
            "$ref": "#/backend/entities/AircraftModelProfile"
          },
          "description": "Stores M&B templates for aircraft models.",
          "params": [
            { "name": "tenantId", "description": "Tenant ID." },
            { "name": "profileId", "description": "Profile ID." }
          ]
        }
      },
      {
        "path": "tenants/{tenantId}",
        "definition": {
          "entityName": "Tenant",
          "schema": {
