
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Grant any authenticated user full access to their user-link document.
    match /users/{userId} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Grant any authenticated user full access to all data within any tenant.
    // In a production app, you would restrict this further based on user roles and tenant membership.
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
