rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isTenantMember(tenantId) {
      // For now, allow any authenticated user for a given tenant.
      // In a real multi-tenant app, you'd check for specific tenant membership.
      return request.auth != null;
    }
    
    // Allow reading of tenant info
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // This rule covers all documents in all subcollections under a tenant,
    // like /tenants/{tenantId}/settings/{settingId} or /tenants/{tenantId}/users/{userId}
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if isTenantMember(tenantId);
    }
  }
}
