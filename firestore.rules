/**
 * This ruleset enforces a strict multi-tenant security model for an aviation academy management application.
 *
 * Core Philosophy:
 * The primary security principle is data isolation between tenants. All application data, except for global user profiles,
 * is strictly partitioned by a tenant ID. A user's affiliation with a tenant and their role within it are determined by
 * Firebase Auth Custom Claims (`request.auth.token.tenantId` and `request.auth.token.role`), which provides a performant
 * and secure way to manage access without extra database reads. Cross-tenant data access is strictly forbidden.
 *
 * Data Structure:
 * The structure consists of two top-level collections:
 * 1. `/users/{userId}`: Stores global user profiles, private to each user.
 * 2. `/tenants/{tenantId}`: Contains documents for each tenant. All other business data (student profiles, aircraft, etc.)
 *    is organized in subcollections under the appropriate tenant document (e.g., /tenants/{tenantId}/aircrafts/{aircraftId}).
 *
 * Key Security Decisions:
 * - Multi-Tenancy via Custom Claims: Access to tenant-specific data requires an auth token containing a matching `tenantId`.
 * - Role-Based Access Control (RBAC): Within a tenant, read access is granted to all members, while write access
 *   (create, update, delete) is restricted to users with an 'admin' role, also specified in their custom claims.
 * - No Public Listing: To prevent data enumeration, listing documents is disabled for top-level collections like `/users`
 *   and `/tenants`. Users can only list documents within the tenant they belong to.
 * - Default Secure: Destructive operations like creating tenants or deleting critical data are disabled from client-side
 *   rules and should be handled by a trusted backend server or admin SDK.
 *
 * Denormalization for Authorization:
 * Instead of performing `get()` calls to user profiles or membership documents to verify tenancy, this ruleset relies on
 * the user's `tenantId` and `role` being denormalized into their Firebase Auth custom claims. This is a highly performant
 * pattern that simplifies security logic (e.g., `request.auth.token.tenantId == tenantId`). Additionally, on document
 * creation, relational keys (e.g., `aircraftId` in a `maintenanceLog`) are validated against the document's path to
 * ensure data integrity from the start.
 *
 * Structural Segregation:
 * The separation of global `/users` from tenant-specific data under `/tenants/{tenantId}` is a clear example of
 * structural segregation. This ensures that the security rules for user profiles (strict ownership) are completely
 * distinct from the rules for tenant data (tenant membership and role-based access).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the authenticated user's UID matches the provided userId.
     * This is the core of the ownership security model.
     * @param userId The user ID to check against the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Returns true if the document being accessed already exists in Firestore.
     * Crucial for protecting against writes on non-existent paths.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Checks if an authenticated user is a member of a specific tenant
     * by verifying the `tenantId` custom claim in their auth token.
     * @param tenantId The ID of the tenant to check membership for.
     */
    function isMemberOfTenant(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    /**
     * Checks if an authenticated user has an 'admin' role within a specific tenant.
     * This relies on both `tenantId` and `role` custom claims.
     * @param tenantId The ID of the tenant to check admin privileges for.
     */
    function isAdminOfTenant(tenantId) {
      return isMemberOfTenant(tenantId) && request.auth.token.role == 'admin';
    }

    /**
     * A secure combination check for update/delete operations on user-owned documents.
     * Ensures the user is the owner AND the document actually exists.
     * @param userId The user ID to check ownership for.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    // --------------------------------
    // Collection Rules
    // --------------------------------

    /**
     * @description Rules for the top-level 'tenants' collection.
     * @path /tenants/{tenantId}
     * @allow (get) An authenticated member of tenant 'acme-corp' reading their own tenant document at `/tenants/acme-corp`.
     * @deny (list) Any user, authenticated or not, attempting to list all tenants.
     * @deny (create) Any client attempting to create a new tenant. This must be done via a backend admin process.
     * @principle Enforces strict tenant data isolation using custom claims and prevents enumeration of tenants.
     */
    match /tenants/{tenantId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if false;
      allow create: if false;
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if false;
    }

    /**
     * @description Rules for the global 'users' collection. Each user document is private.
     * @path /users/{userId}
     * @allow (create) A new user with uid 'user123' creating their own profile at `/users/user123`.
     * @allow (get) User 'user123' reading their own profile.
     * @deny (get) User 'user123' trying to read `/users/user456`.
     * @deny (list) Any user trying to get a list of all application users.
     * @principle Restricts access to a user's own data tree (Ownership).
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Generic rules for tenant-specific data collections that do not have subcollections.
     * These include student profiles, instructors, and personnel records.
     * @path /tenants/{tenantId}/studentProfiles/{studentProfileId}
     * @path /tenants/{tenantId}/instructors/{instructorId}
     * @path /tenants/{tenantId}/personnel/{personnelId}
     * @path /tenants/{tenantId}/roles/{roleId}
     * @allow (get, list) Any member of tenant 'acme-corp' reading or listing documents within these collections.
     * @allow (create) An admin of tenant 'acme-corp' creating a new document.
     * @deny (create) A non-admin member of tenant 'acme-corp' trying to create a new document.
     * @deny (get) A user from tenant 'bravocorp' attempting to access any data from 'acme-corp'.
     * @principle Enforces tenant isolation and a standard Read (member) / Write (admin) RBAC model.
     */
    match /tenants/{tenantId}/{collection=**}/_ {
      allow read, write: if false;
    }
    match /tenants/{tenantId}/studentProfiles/{studentProfileId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
    }
    match /tenants/{tenantId}/instructors/{instructorId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
    }
    match /tenants/{tenantId}/personnel/{personnelId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
    }
    match /tenants/{tenantId}/roles/{roleId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
    }

    /**
     * @description Rules for the 'aircrafts' collection within a tenant.
     * @path /tenants/{tenantId}/aircrafts/{aircraftId}
     * @allow (list) A member of tenant 'acme-corp' listing all aircraft.
     * @allow (create) An admin of tenant 'acme-corp' adding a new aircraft.
     * @deny (update) A non-admin member of 'acme-corp' trying to modify an aircraft record.
     * @principle Enforces tenant isolation and RBAC for a parent collection.
     */
    match /tenants/{tenantId}/aircrafts/{aircraftId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();

      /**
       * @description Rules for aircraft maintenance logs, which are nested under an aircraft.
       * @path /tenants/{tenantId}/aircrafts/{aircraftId}/maintenanceLogs/{maintenanceLogId}
       * @allow (create) An admin of tenant 'acme-corp' creating a maintenance log with `aircraftId` matching the path.
       * @deny (create) An admin of tenant 'acme-corp' creating a log where `request.resource.data.aircraftId` is mismatched.
       * @deny (update) An admin attempting to change the `aircraftId` of an existing log.
       * @principle Inherits tenant security from the path and validates relational integrity on writes.
       */
      match /maintenanceLogs/{maintenanceLogId} {
        allow get: if isMemberOfTenant(tenantId);
        allow list: if isMemberOfTenant(tenantId);
        allow create: if isAdminOfTenant(tenantId) && request.resource.data.aircraftId == aircraftId;
        allow update: if isAdminOfTenant(tenantId) && isExistingDoc() && request.resource.data.aircraftId == resource.data.aircraftId;
        allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
      }
    }

    /**
     * @description Rules for the 'safetyProtocols' collection within a tenant.
     * @path /tenants/{tenantId}/safetyProtocols/{safetyProtocolId}
     * @allow (list) A member of tenant 'acme-corp' listing all safety protocols.
     * @allow (create) An admin of tenant 'acme-corp' adding a new protocol.
     * @deny (update) A non-admin member of 'acme-corp' trying to modify a protocol.
     * @principle Enforces tenant isolation and RBAC for a parent collection.
     */
    match /tenants/{tenantId}/safetyProtocols/{safetyProtocolId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId);
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc();
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();

      /**
       * @description Rules for compliance checks, which are nested under a safety protocol.
       * @path /tenants/{tenantId}/safetyProtocols/{safetyProtocolId}/complianceChecks/{complianceCheckId}
       * @allow (create) An admin of tenant 'acme-corp' creating a check with `safetyProtocolId` matching the path.
       * @deny (create) An admin of tenant 'acme-corp' creating a check where `request.resource.data.safetyProtocolId` is mismatched.
       * @deny (update) An admin attempting to change the `safetyProtocolId` of an existing check.
       * @principle Inherits tenant security from the path and validates relational integrity on writes.
       */
      match /complianceChecks/{complianceCheckId} {
        allow get: if isMemberOfTenant(tenantId);
        allow list: if isMemberOfTenant(tenantId);
        allow create: if isAdminOfTenant(tenantId) && request.resource.data.safetyProtocolId == safetyProtocolId;
        allow update: if isAdminOfTenant(tenantId) && isExistingDoc() && request.resource.data.safetyProtocolId == resource.data.safetyProtocolId;
        allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
      }
    }
    
    /**
     * @description Rules for the 'settings' collection within a tenant.
     * @path /tenants/{tenantId}/settings/{settingsId}
     * @allow (create) An admin of tenant 'acme-corp' creating a settings document with `tenantId` matching the path.
     * @deny (create) An admin of tenant 'acme-corp' creating a settings document with a mismatched `tenantId`.
     * @deny (update) An admin attempting to change the `tenantId` of an existing settings document.
     * @principle Inherits tenant security and validates the internal `tenantId` field for data consistency.
     */
    match /tenants/{tenantId}/settings/{settingsId} {
      allow get: if isMemberOfTenant(tenantId);
      allow list: if isMemberOfTenant(tenantId);
      allow create: if isAdminOfTenant(tenantId) && request.resource.data.tenantId == tenantId;
      allow update: if isAdminOfTenant(tenantId) && isExistingDoc() && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if isAdminOfTenant(tenantId) && isExistingDoc();
    }
  }
}