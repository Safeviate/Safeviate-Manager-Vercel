
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Grant any authenticated user full access to their user-link document.
    match /users/{userId} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Grant read-only access to all authenticated users for all tenant data.
    // In a production app, you would restrict this further based on user roles and tenant membership.
    match /tenants/{tenantId} {
      allow get: if request.auth != null;
    }
    
    match /tenants/{tenantId}/aircrafts/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/audit-schedule-items/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/bookings/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/compliance-matrix/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/corrective-action-plans/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/counters/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/departments/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/flight-plans/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/instructors/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/logbook-templates/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/management-of-change/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/massAndBalance/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/permissions/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/personnel/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/pilots/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/private-pilots/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/published-tables/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/quality-audit-templates/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/quality-audits/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/risks/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/roles/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/safety-reports/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/settings/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/student-progress-reports/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/students/{docId} { allow read, write: if request.auth != null; }
    match /tenants/{tenantId}/table-templates/{docId} { allow read, write: if request.auth != null; }

  }
}
