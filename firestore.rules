
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Grant any authenticated user full access to their user-link document.
    match /users/{userId} {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /tenants/{tenantId} {
      // Allow reading/writing the tenant document itself.
      allow read, write: if request.auth != null;

      // Rules for all sub-collections within a tenant.
      match /published-tables/{pageId} {
        allow read, write: if request.auth != null;
      }
      match /table-templates/{templateId} {
        allow read, write: if request.auth != null;
      }
      match /compliance-matrix/{itemId} {
        allow read, write: if request.auth != null;
      }
      match /audit-schedule-items/{itemId} {
        allow read, write: if request.auth != null;
      }
      match /quality-audit-templates/{templateId} {
        allow read, write: if request.auth != null;
      }
      match /quality-audits/{auditId} {
        allow read, write: if request.auth != null;
      }
      match /corrective-action-plans/{capId} {
        allow read, write: if request.auth != null;
      }
      match /flight-plans/{flightPlanId} {
        allow read, write: if request.auth != null;
      }
      match /risks/{riskId} {
        allow read, write: if request.auth != null;
      }
      match /safety-reports/{reportId} {
        allow read, write: if request.auth != null;
      }
      match /management-of-change/{mocId} {
        allow read, write: if request.auth != null;
      }
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null;
      }
      match /logbook-templates/{templateId} {
        allow read, write: if request.auth != null;
      }
      match /massAndBalance/{profileId} {
        allow read, write: if request.auth != null;
      }
      match /personnel/{personnelId} {
        allow read, write: if request.auth != null;
      }
      match /pilots/{pilotId} {
        allow read, write: if request.auth != null;
      }
       match /instructors/{instructorId} {
        allow read, write: if request.auth != null;
      }
       match /students/{studentId} {
        allow read, write: if request.auth != null;
      }
       match /private-pilots/{privatePilotId} {
        allow read, write: if request.auth != null;
      }
      match /aircrafts/{aircraftId} {
        allow read, write: if request.auth != null;
        match /maintenanceLogs/{maintenanceLogId} {
            allow read, write: if request.auth != null;
        }
      }
      match /roles/{roleId} {
        allow read, write: if request.auth != null;
      }
      match /permissions/{permissionId} {
        allow read, write: if request.auth != null;
      }
      match /settings/{settingsId} {
        allow read, write: if request.auth != null;
      }
      match /departments/{departmentId} {
        allow read, write: if request.auth != null;
      }
      match /counters/{counterId} {
        allow read, write: if request.auth != null;
      }
      match /student-progress-reports/{reportId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
