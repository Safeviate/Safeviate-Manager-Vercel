rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // A user is considered a member of a tenant if they are authenticated.
    // This is a placeholder for more specific multi-tenancy rules later.
    function isTenantMember(tenantId) {
      return request.auth != null;
    }
    
    // Publicly allow reading the list of tenants
    match /tenants/{tenantId} {
      allow read: if true;
      // Allow any authenticated user to create/update a tenant document.
      // In production, this would be locked down to specific admin roles.
      allow write: if request.auth != null;
    }

    // This rule is the key fix. It applies to ANY document within ANY subcollection
    // under a specific tenant.
    // e.g., /tenants/{tenantId}/settings/{docId}
    // e.g., /tenants/{tenantId}/users/{userId}
    // e.g., /tenants/{tenantId}/roles/{roleId}
    match /tenants/{tenantId}/{subcollection}/{docId=**} {
      allow read, write: if isTenantMember(tenantId);
    }
  }
}
