rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Universal recursive match: Allow all operations for authenticated users.
    // This is the most robust rule to ensure Barry and other personnel have 
    // seamless access to all tenant data, including bookings, students, and settings.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
