rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTenantMember(tenantId) {
      // In a real app, you would check if the user is part of the tenant.
      // For now, we'll allow any authenticated user for a given tenant.
      return request.auth != null;
    }
    
    // Tenants can be read by anyone, but only created/updated by authenticated users.
    match /tenants/{tenantId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rules for all collections under a tenant
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if isTenantMember(tenantId);
    }
  }
}
