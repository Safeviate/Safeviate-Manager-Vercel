{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user's link between authentication and their profile data.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePath": { "type": "string" }
      },
      "required": ["id", "email", "profilePath"]
    },
    "ERPContact": {
      "title": "ERP Contact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "organization": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "priority": { "type": "number" },
        "category": { "type": "string", "enum": ["Internal", "Aviation Authorities", "Emergency Services", "External Partners"] }
      },
      "required": ["id", "name", "role", "phone", "category"]
    },
    "ERPEvent": {
      "title": "ERP Event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Mock", "Active", "Closed"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "endedAt": { "type": "string", "format": "date-time" },
        "log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "description": { "type": "string" },
              "userName": { "type": "string" },
              "isMilestone": { "type": "boolean" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile link."
        }
      },
      {
        "path": "tenants/{tenantId}/erp-contacts/{contactId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/ERPContact" },
          "description": "Emergency contacts for ERP."
        }
      },
      {
        "path": "tenants/{tenantId}/erp-events/{eventId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/ERPEvent" },
          "description": "Real-time ERP response logs."
        }
      }
    ]
  }
}