{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user's link between authentication and their profile data.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePath": { "type": "string" }
      },
      "required": ["id", "email", "profilePath"]
    },
    "ERPContact": {
      "title": "ERP Contact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "organization": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "priority": { "type": "number" },
        "category": { "type": "string", "enum": ["Internal", "Aviation Authorities", "Emergency Services", "External Partners"] }
      },
      "required": ["id", "name", "role", "phone", "category"]
    },
    "ERPEvent": {
      "title": "ERP Event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["Mock", "Active", "Closed"] }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingNumber": { "type": "string" },
        "aircraftId": { "type": "string" },
        "status": { "type": "string" },
        "accountingStatus": { "type": "string", "enum": ["Unbilled", "Exported", "Paid"] },
        "totalCost": { "type": "number" }
      }
    },
    "Aircraft": {
      "title": "Aircraft",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tailNumber": { "type": "string" },
        "hourlyRate": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile link."
        }
      },
      {
        "path": "tenants/{tenantId}/erp-contacts/{contactId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/ERPContact" },
          "description": "Emergency contacts."
        }
      },
      {
        "path": "tenants/{tenantId}/bookings/{bookingId}",
        "definition": {
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Flight bookings."
        }
      }
    ]
  }
}
